# Puerto del backend
PORT=8008

# Entorno
NODE_ENV=development

# URL de conexión de Neon (PostgreSQL)
# Nunca subas credenciales reales a git
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB_NAME?sslmode=require&channel_binding=require"

# Lista de orígenes permitidos por CORS, separados por coma
CORS_ALLOWED_ORIGINS="http://localhost:3000"

# Secreto JWT (mínimo 32 caracteres para entorno real)
JWT_SECRET="CHANGE_ME_SUPER_SECRET_32_CHARS_MIN"
